# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# reCAPTCHA v3 (recommended for production public forms)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Optional analytics (loads only after user accepts analytics cookies)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXX

# Optional: set when developing through ngrok (enables WSS HMR over the tunnel)
# VITE_NGROK_HOST=your-subdomain.ngrok-free.dev

# Super admin bootstrap script only (never commit real values)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change-me-on-first-run

# Required for provision-user Edge Function (set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...)
# Deploy with: bun run functions:deploy
#
# reCAPTCHA v3 (supabase secrets set on linked project)
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
# RECAPTCHA_MIN_SCORE=0.5

# Resend email (supabase secrets set on linked project — never commit real keys)
# RESEND_API_KEY=re_...
# EMAIL_FROM=EasyPortal <no-reply@easyportal.ca>
# PORTAL_APP_URL=https://your-portal-domain

# Optional: Google Gemini for vendor certificate expiry extraction (supabase secrets set)
# GEMINI_API_KEY=your-google-api-key

# Optional: protect scheduled vendor-compliance-reminders cron (supabase secrets set on linked project)
# CRON_SECRET=your-random-secret
#
# After db push, store matching values in Supabase Vault (see scripts/setup-vendor-compliance-cron-vault.sql).
# pg_cron runs daily at 08:00 UTC: vendor-compliance-reminders-daily

# QuickBooks Online Edge Functions (supabase secrets set ... on linked project)
#
# Real client accounts (production QuickBooks companies):
#   Use Keys from Intuit Developer Portal → Production tab (NOT Development/Sandbox).
#   Set INTUIT_ENV=production (default if omitted).
#
# Local/dev sandbox testing only:
#   Use Development keys + an Intuit sandbox test company.
#   Set INTUIT_ENV=sandbox
#
# INTUIT_CLIENT_ID=your-production-or-sandbox-client-id
# INTUIT_CLIENT_SECRET=your-production-or-sandbox-client-secret
# INTUIT_REDIRECT_URL=https://your-project.supabase.co/functions/v1/qbo-oauth-callback
# INTUIT_ENV=production
# PORTAL_APP_URL=http://localhost:5173
